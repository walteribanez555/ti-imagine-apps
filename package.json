{
  "name": "ti-imagine-apps",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "turbo": "^2.9.15",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.6.1",
  "workspaces": [
    "apps/*"
  ],
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  }
}

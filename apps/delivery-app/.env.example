# ============================================================
# delivery-app — Expo / React Native Environment Template
# Copy this file to .env and fill in your values.
# ============================================================

# ----- Backend REST API -------------------------------------
EXPO_PUBLIC_API_URL=http://<your-machine-ip>:3001

# ----- WebSocket / Socket.IO --------------------------------
EXPO_PUBLIC_WS_URL=http://<your-machine-ip>:3001
EXPO_PUBLIC_WS_NAMESPACE=/orders

# ----- Misc -------------------------------------------------
EXPO_PUBLIC_DEBUG=false

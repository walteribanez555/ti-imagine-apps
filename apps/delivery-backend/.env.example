# ============================================================
# delivery-backend — Environment Variables Template
# Copy this file to .env and fill in your values.
# Also consumed by docker-compose.yml for infrastructure setup.
# ============================================================

# ----- Server -----------------------------------------------
NODE_ENV=development
PORT=3001

# ----- MongoDB (app connection) -----------------------------
MONGODB_URI=mongodb://<user>:<password>@<host>:<port>/<database>

# ----- Redis (app connection) -------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ----- CORS -------------------------------------------------
CORS_ORIGIN=http://localhost:8081,http://localhost:19006

# ----- WebSocket Gateway ------------------------------------
WS_NAMESPACE=/orders

# ----- Security ---------------------------------------------
# JWT_SECRET=
# JWT_EXPIRES_IN=3600s

# ============================================================
# Docker Compose infrastructure vars
# Used by docker-compose.yml to bootstrap MongoDB & Redis.
# ============================================================
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=secret
MONGO_DB=delivery_db
MONGO_PORT=27017
BACKEND_PORT=3001
